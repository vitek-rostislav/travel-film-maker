{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travel-film-maker.local/schemas/asset.schema.json",
  "title": "Travel Film Maker Assets",
  "type": "object",
  "required": ["assets"],
  "properties": {
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "path"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["photo", "video"] },
          "path": { "type": "string" },
          "captured_at": { "type": "string" },
          "duration": { "type": "number" },
          "location": { "type": "object" },
          "technical": { "type": "object" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
