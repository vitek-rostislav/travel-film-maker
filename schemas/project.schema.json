{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travel-film-maker.local/schemas/project.schema.json",
  "title": "Travel Film Maker Project Model",
  "type": "object",
  "required": ["project", "trip", "days"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["title", "style", "language", "aspect_ratio"],
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "style": { "type": "string" },
        "language": { "type": "string" },
        "aspect_ratio": { "type": "string" }
      }
    },
    "trip": {
      "type": "object",
      "properties": {
        "totals": { "type": "object" },
        "route": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "media_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "enum": [
              "google_photos_shared_album",
              "local_folder",
              "google_drive",
              "icloud_export",
              "dropbox",
              "onedrive"
            ]
          },
          "url": { "type": "string" },
          "path": { "type": "string" },
          "mapping": { "type": "object" }
        }
      }
    },
    "days": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "date", "title", "location", "route", "highlights", "assets", "map", "mood"],
        "properties": {
          "id": { "type": "string" },
          "date": { "type": "string" },
          "title": { "type": "string" },
          "location": { "type": "string" },
          "route": { "type": "string" },
          "country_flags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "stats": { "type": "object" },
          "highlights": {
            "type": "array",
            "items": { "type": "string" }
          },
          "assets": {
            "type": "object",
            "properties": {
              "folder": { "type": "string" }
            }
          },
          "media": {
            "type": "object",
            "required": ["source"],
            "properties": {
              "source": { "type": "string" },
              "filters": { "type": "object" }
            }
          },
          "map": { "type": "object" },
          "mood": { "type": "string" }
        }
      }
    }
  }
}
