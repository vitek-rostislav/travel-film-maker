{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travel-film-maker.local/schemas/timeline.schema.json",
  "title": "Travel Film Maker Normalized Timeline",
  "type": "object",
  "required": ["timeline"],
  "properties": {
    "timeline": {
      "type": "object",
      "required": ["schema", "fps", "aspect_ratio", "duration_seconds", "items"],
      "properties": {
        "schema": { "type": "string" },
        "fps": { "type": "integer" },
        "aspect_ratio": { "type": "string" },
        "duration_seconds": { "type": "integer" },
        "items": { "type": "array" }
      }
    }
  }
}
